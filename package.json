{
  "name": "csvbudgettracker",
  "version": "1.0.0",
  "private": true,
  "description": "CSV Budget Tracker — offline, encrypted React Native Android budgeting app that imports bank CSV exports, detects recurring subscriptions, and tracks spending with smooth up-to-120fps animations.",
  "license": "MIT",
  "main": "index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "android": "react-native run-android",
    "android:release": "cd android && ./gradlew assembleRelease",
    "start": "react-native start",
    "lint": "eslint . --ext .js,.jsx",
    "test": "jest",
    "bundle:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output /tmp/index.android.bundle --assets-dest /tmp"
  },
  "dependencies": {
    "@d11/react-native-fast-image": "8.13.0",
    "@react-navigation/bottom-tabs": "7.18.2",
    "@react-navigation/native": "7.3.3",
    "@react-navigation/stack": "7.10.5",
    "crypto-js": "4.2.0",
    "lodash": "4.17.21",
    "papaparse": "5.5.4",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-biometrics": "3.0.1",
    "react-native-document-picker": "9.3.1",
    "react-native-encrypted-storage": "4.0.3",
    "react-native-fs": "2.20.0",
    "react-native-gesture-handler": "2.21.2",
    "react-native-get-random-values": "1.11.0",
    "react-native-paper": "5.15.3",
    "react-native-reanimated": "3.16.7",
    "react-native-safe-area-context": "4.14.1",
    "react-native-screens": "4.5.0",
    "react-native-sqlite-storage": "6.0.1",
    "react-native-svg": "15.15.5",
    "react-native-vector-icons": "10.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "15.0.1",
    "@react-native-community/cli-platform-android": "15.0.1",
    "@react-native/babel-preset": "0.76.9",
    "@react-native/eslint-config": "0.76.9",
    "@react-native/metro-config": "0.76.9",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "18.3.1"
  },
  "jest": {
    "preset": "react-native"
  }
}
