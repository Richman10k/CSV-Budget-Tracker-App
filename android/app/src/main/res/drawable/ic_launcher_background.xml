<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive icon background: deep neon-indigo diagonal gradient with a soft
     top-left light glow, for premium "Liquid Glass" depth. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Base diagonal indigo gradient (bright -> brand -> deep). -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="6" android:startY="4"
                android:endX="102" android:endY="106">
                <item android:offset="0" android:color="#FF8E97FA" />
                <item android:offset="0.52" android:color="#FF6366F1" />
                <item android:offset="1" android:color="#FF332C9E" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Soft radial highlight from the top-left (simulated light source). -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="34" android:centerY="26"
                android:gradientRadius="84">
                <item android:offset="0" android:color="#33FFFFFF" />
                <item android:offset="1" android:color="#00FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
